# EgoZone Security Configuration Example
# Generated: February 18, 2025
#
# IMPORTANT: Do not use default example values in production!
# All sensitive configurations must be modified before use

# Application basic configuration
APP_NAME=EgoZone
DEBUG=false
SECRET_KEY=Set-a-strong-secret-key-here-recommend-using-randomly-generated-long-string

# Gemini / Vertex AI configuration
GEMINI_API_KEY=Set-your-Google-AI-API-key-here
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Database
DATABASE_URL=sqlite:///./egozone.db

# Redis (optional)
REDIS_URL=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# Google Cloud (voice service, optional)
GOOGLE_CLOUD_PROJECT=

# Admin password (strongly recommend 12+ characters with uppercase, lowercase, numbers, and special characters)
ADMIN_PASSWORD=Set-a-strong-admin-password-here

# Public access password (strongly recommend 12+ characters with uppercase, lowercase, numbers, and special characters)
ACCESS_PASSWORD=Set-a-strong-access-password-here

# Google Cloud Storage (persistent storage)
GCS_BUCKET=your-egozone-data-bucket
USE_GCS=false