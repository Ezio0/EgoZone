# EgoZone 安全配置示例
# 生成时间: 2025年2月18日
#
# 重要：不要在生产环境使用默认示例值！
# 使用前必须修改以下所有敏感配置

# 应用基础配置
APP_NAME=EgoZone
DEBUG=false
SECRET_KEY=在此处设置强密钥-推荐使用随机生成的长字符串

# Gemini / Vertex AI 配置
GEMINI_API_KEY=在此处设置Google AI API密钥
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# 数据库
DATABASE_URL=sqlite:///./egozone.db

# Redis (可选)
REDIS_URL=

# Telegram (可选)
TELEGRAM_BOT_TOKEN=

# Google Cloud (语音服务，可选)
GOOGLE_CLOUD_PROJECT=

# 管理员密码（强烈建议使用12+位包含大小写、数字和特殊字符的强密码）
ADMIN_PASSWORD=在此处设置强管理员密码

# 公共访问密码（强烈建议使用12+位包含大小写、数字和特殊字符的强密码）
ACCESS_PASSWORD=在此处设置强访问密码

# Google Cloud Storage（持久化存储）
GCS_BUCKET=your-egozone-data-bucket
USE_GCS=false
