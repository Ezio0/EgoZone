# EgoZone 安全配置示例
# 请复制此文件为 .env 并根据需要修改密码

# 应用基础配置
APP_NAME=EgoZone
DEBUG=false
SECRET_KEY=your-very-secure-secret-key-here-change-this-in-production

# Gemini / Vertex AI 配置
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3-flash-preview
GCP_PROJECT=egozone
GCP_LOCATION=us-central1

# 数据库
DATABASE_URL=sqlite:///./egozone.db

# Redis (可选)
REDIS_URL=

# Telegram (可选)
TELEGRAM_BOT_TOKEN=

# Google Cloud (语音服务，可选)
GOOGLE_CLOUD_PROJECT=

# 管理员密码（用于访问问答采集、知识库、设置功能）
# 要求：至少12位，包含大小写字母、数字和特殊字符
ADMIN_PASSWORD=SecureAdminPass123!@#

# 公共访问密码（用于访问对话功能，防止恶意攻击）
# 要求：至少12位，包含大小写字母、数字和特殊字符
ACCESS_PASSWORD=SecureAccessPass456!@#

# Google Cloud Storage（持久化存储）
GCS_BUCKET=egozone-data
USE_GCS=false  # 本地开发设为false，生产环境设为true

# 安全配置提示：
# 1. 务必修改所有默认密码
# 2. 使用强密码策略（12位以上，混合字符类型）
# 3. 定期更换密码
# 4. 生产环境启用HTTPS
# 5. 配置适当的防火墙规则