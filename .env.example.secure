# EgoZone Security Configuration
# Generated: 2025
#
# IMPORTANT: Never commit this file to version control!
# This file should remain in .gitignore
#
# Setup Instructions:
# 1. Copy this file: cp .env.example.secure .env
# 2. Replace ALL placeholder values below with your actual credentials
# 3. Use strong passwords (16+ characters with mixed case, numbers, symbols)
# 4. Generate SECRET_KEY using: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# 5. Get your GEMINI_API_KEY from Google AI Studio or Google Cloud Console

# Application Settings
APP_NAME=EgoZone
DEBUG=false
SECRET_KEY=REPLACE_WITH_YOUR_GENERATED_SECRET_KEY

# Gemini / Vertex AI Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-3-flash-preview
GCP_PROJECT=REPLACE_WITH_YOUR_GCP_PROJECT_ID
GCP_LOCATION=us-central1
GCP_PROJECT_ID=REPLACE_WITH_YOUR_GCP_PROJECT_ID
GCP_REGION=us-central1

# Database
DATABASE_URL=sqlite:///./egozone.db

# Redis (Optional)
REDIS_URL=

# Telegram Bot (Optional)
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Google Cloud (Voice Services, Optional)
GOOGLE_CLOUD_PROJECT=

# Admin Password (Required - for accessing admin features)
# Requirements: 16+ characters, uppercase, lowercase, numbers, special characters
# Generate using: python3 -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'!@#$%^&*') for _ in range(16)))"
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD_16_CHARS_MIN

# Public Access Password (Required - for chat access)
# Requirements: 16+ characters, uppercase, lowercase, numbers, special characters
ACCESS_PASSWORD=REPLACE_WITH_STRONG_ACCESS_PASSWORD_16_CHARS_MIN

# Google Cloud Storage (Persistent Storage)
GCS_BUCKET=egozone-data
USE_GCS=false

# Security Checklist:
# [ ] SECRET_KEY is randomly generated (not default/example value)
# [ ] GEMINI_API_KEY is from Google AI Studio (not shared/default)
# [ ] ADMIN_PASSWORD is 16+ chars with mixed types
# [ ] ACCESS_PASSWORD is 16+ chars with mixed types
# [ ] This file is listed in .gitignore
# [ ] Old/exposed credentials have been rotated in cloud console
